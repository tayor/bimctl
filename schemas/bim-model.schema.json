{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tayor.github.io/bimctl/schemas/bim-model.schema.json",
  "title": "bimctl BIM Model",
  "type": "object",
  "required": ["project", "spaces"],
  "properties": {
    "schema": {
      "const": "https://tayor.github.io/bimctl/schemas/bim-model.schema.json"
    },
    "bimctlVersion": {
      "type": "string"
    },
    "units": {
      "const": "m"
    },
    "project": {
      "type": "object",
      "required": ["id", "name"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": "string" }
      },
      "additionalProperties": false
    },
    "site": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "latitude": { "type": "number", "minimum": -90, "maximum": 90 },
        "longitude": { "type": "number", "minimum": -180, "maximum": 180 },
        "timeZone": { "type": "number", "minimum": -12, "maximum": 14 },
        "elevationM": { "type": "number" }
      },
      "additionalProperties": false
    },
    "spaces": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/space" }
    },
    "simulation": {
      "type": "object",
      "properties": {
        "timestepsPerHour": { "type": "integer", "minimum": 1, "maximum": 60 },
        "runDesignDays": { "type": "boolean" },
        "runWeatherFile": { "type": "boolean" },
        "outputs": {
          "type": "array",
          "items": {
            "enum": ["zoneTemperature", "electricity", "heating", "cooling"]
          }
        }
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "space": {
      "type": "object",
      "required": ["id", "name", "dimensions"],
      "properties": {
        "id": { "type": "string", "pattern": "^[A-Za-z][A-Za-z0-9_-]*$" },
        "name": { "type": "string", "minLength": 1 },
        "type": { "enum": ["office", "residential", "classroom", "retail", "storage", "generic"] },
        "origin": { "$ref": "#/$defs/point3" },
        "dimensions": { "$ref": "#/$defs/dimensions" },
        "thermal": { "$ref": "#/$defs/thermal" },
        "windows": {
          "type": "array",
          "items": { "$ref": "#/$defs/window" }
        }
      },
      "additionalProperties": false
    },
    "point3": {
      "type": "object",
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" },
        "z": { "type": "number" }
      },
      "additionalProperties": false
    },
    "dimensions": {
      "type": "object",
      "required": ["width", "depth", "height"],
      "properties": {
        "width": { "type": "number", "exclusiveMinimum": 0 },
        "depth": { "type": "number", "exclusiveMinimum": 0 },
        "height": { "type": "number", "exclusiveMinimum": 0 }
      },
      "additionalProperties": false
    },
    "thermal": {
      "type": "object",
      "properties": {
        "people": { "type": "number", "minimum": 0 },
        "lightingWPerM2": { "type": "number", "minimum": 0 },
        "equipmentWPerM2": { "type": "number", "minimum": 0 },
        "infiltrationAirChangesPerHour": { "type": "number", "minimum": 0 },
        "heatingSetpointC": { "type": "number" },
        "coolingSetpointC": { "type": "number" }
      },
      "additionalProperties": false
    },
    "window": {
      "type": "object",
      "required": ["id", "wall", "width", "height"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "wall": { "enum": ["north", "east", "south", "west"] },
        "width": { "type": "number", "exclusiveMinimum": 0 },
        "height": { "type": "number", "exclusiveMinimum": 0 },
        "sillHeight": { "type": "number", "minimum": 0 },
        "offset": { "type": "number", "minimum": 0 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}